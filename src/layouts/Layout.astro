---
interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical = 'https://java-ai-memory.dev/' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fafaf7" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <style is:global>
      :root {
        --bg: #fafaf7;
        --bg-alt: #f4f3ee;
        --surface: #ffffff;
        --text: #1a1a1a;
        --text-secondary: #4a4a4a;
        --text-muted: #6b7280;
        --border: #e5e3dd;
        --border-strong: #c9c7be;
        --accent: #1d4ed8;
        --accent-light: #dbeafe;
        --success: #059669;
        --warning: #b45309;
        --danger: #991b1b;
        --neutral: #6b7280;

        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        --font-serif: 'Source Serif 4', Georgia, 'Times New Roman', serif;
        --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, Monaco, monospace;

        --max-width: 1120px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        padding: 0;
        font-family: var(--font-serif);
        font-size: 17px;
        line-height: 1.7;
        color: var(--text);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: var(--font-sans);
        color: var(--text);
        line-height: 1.3;
        font-weight: 600;
      }

      code,
      pre {
        font-family: var(--font-mono);
        font-size: 0.88em;
      }

      pre {
        background: #f8f8f4;
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 16px 18px;
        overflow-x: auto;
        line-height: 1.6;
        margin: 0;
      }

      code {
        background: var(--bg-alt);
        padding: 1px 6px;
        border-radius: 3px;
      }

      pre code {
        background: none;
        padding: 0;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 24px;
      }

      .container-narrow {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* Header */
      .site-header {
        padding: 28px 0 20px;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
      }

      .site-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
      }

      .site-title {
        font-family: var(--font-sans);
        font-size: 20px;
        font-weight: 700;
        color: var(--text);
        margin: 0;
      }

      .site-title a {
        color: inherit;
        text-decoration: none;
      }

      .site-nav {
        display: flex;
        gap: 24px;
        font-family: var(--font-sans);
        font-size: 14px;
      }

      .site-nav a {
        color: var(--text-secondary);
      }

      /* Hero */
      .hero {
        padding: 72px 0 48px;
        border-bottom: 1px solid var(--border);
      }

      .hero h1 {
        font-family: var(--font-serif);
        font-size: 52px;
        font-weight: 600;
        line-height: 1.15;
        margin: 0 0 24px;
        letter-spacing: -0.02em;
      }

      .hero h1 em {
        font-style: italic;
        color: var(--accent);
      }

      .hero-lede {
        font-size: 20px;
        line-height: 1.6;
        color: var(--text-secondary);
        max-width: 680px;
        margin: 0 0 32px;
      }

      .hero-meta {
        font-family: var(--font-sans);
        font-size: 13px;
        color: var(--text-muted);
      }

      .hero-meta a {
        color: var(--text-muted);
        text-decoration: underline;
      }

      /* Section */
      .section {
        padding: 64px 0;
        border-bottom: 1px solid var(--border);
      }

      .section-label {
        font-family: var(--font-sans);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        display: block;
        margin-bottom: 12px;
      }

      .section h2 {
        font-family: var(--font-serif);
        font-size: 36px;
        font-weight: 600;
        margin: 0 0 16px;
        letter-spacing: -0.01em;
      }

      .section-intro {
        font-size: 18px;
        color: var(--text-secondary);
        max-width: 720px;
        margin: 0 0 40px;
        line-height: 1.7;
      }

      /* Matrix */
      .matrix-wrap {
        overflow-x: auto;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
      }

      .matrix {
        width: 100%;
        border-collapse: collapse;
        font-family: var(--font-sans);
        font-size: 13px;
        min-width: 900px;
      }

      .matrix th,
      .matrix td {
        padding: 10px 12px;
        text-align: left;
        border-bottom: 1px solid var(--border);
        border-right: 1px solid var(--border);
      }

      .matrix th:last-child,
      .matrix td:last-child {
        border-right: none;
      }

      .matrix tr:last-child td {
        border-bottom: none;
      }

      .matrix thead th {
        background: var(--bg-alt);
        font-weight: 600;
        color: var(--text);
        position: sticky;
        top: 0;
        z-index: 1;
        font-size: 12px;
      }

      .matrix thead th:first-child {
        background: var(--bg-alt);
        position: sticky;
        left: 0;
        z-index: 2;
      }

      .matrix tbody th {
        font-weight: 500;
        color: var(--text-secondary);
        background: var(--surface);
        position: sticky;
        left: 0;
        z-index: 1;
        text-align: left;
      }

      .matrix td {
        text-align: center;
        font-size: 16px;
        vertical-align: middle;
      }

      .support-yes {
        color: var(--success);
        font-weight: 700;
      }

      .support-no {
        color: var(--danger);
        opacity: 0.6;
      }

      .support-partial {
        color: var(--warning);
        font-weight: 700;
      }

      .support-na {
        color: var(--text-muted);
        opacity: 0.4;
      }

      .matrix-legend {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
        margin-top: 16px;
        font-family: var(--font-sans);
        font-size: 13px;
        color: var(--text-muted);
      }

      .matrix-legend span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      /* Cards */
      .library-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 32px;
        margin-bottom: 24px;
        scroll-margin-top: 80px;
      }

      .library-card-header {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 8px;
      }

      .library-card h3 {
        font-family: var(--font-serif);
        font-size: 28px;
        font-weight: 600;
        margin: 0;
        letter-spacing: -0.01em;
      }

      .library-card h3 a {
        color: inherit;
      }

      .library-tagline {
        font-style: italic;
        color: var(--text-secondary);
        margin: 0 0 20px;
        font-size: 17px;
      }

      .library-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 20px;
      }

      .badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 4px;
        font-family: var(--font-sans);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.02em;
      }

      .badge-category {
        background: var(--accent-light);
        color: var(--accent);
      }

      .badge-active {
        background: #d1fae5;
        color: #065f46;
      }

      .badge-community {
        background: #fef3c7;
        color: #92400e;
      }

      .badge-abandoned {
        background: #fee2e2;
        color: #991b1b;
      }

      .badge-does-not-exist {
        background: #f3f4f6;
        color: #4b5563;
      }

      .badge-lang,
      .badge-license,
      .badge-stars {
        background: var(--bg-alt);
        color: var(--text-secondary);
      }

      .library-description {
        line-height: 1.7;
        margin-bottom: 24px;
      }

      .library-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
      }

      .library-grid h4 {
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin: 0 0 10px;
      }

      .library-grid ul {
        margin: 0;
        padding-left: 18px;
        font-size: 15px;
        line-height: 1.6;
      }

      .library-grid li {
        margin-bottom: 6px;
        color: var(--text-secondary);
      }

      .library-code {
        margin: 20px 0;
      }

      .library-links {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        font-family: var(--font-sans);
        font-size: 14px;
      }

      .library-links a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: var(--bg-alt);
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text-secondary);
        text-decoration: none;
        transition: all 0.15s;
      }

      .library-links a:hover {
        background: var(--surface);
        border-color: var(--accent);
        color: var(--accent);
      }

      .library-notes {
        margin-top: 16px;
        padding: 12px 16px;
        background: var(--bg-alt);
        border-left: 3px solid var(--border-strong);
        font-size: 15px;
        color: var(--text-secondary);
        font-style: italic;
      }

      .library-maven-coords {
        font-family: var(--font-mono);
        font-size: 13px;
        background: var(--bg-alt);
        padding: 6px 10px;
        border-radius: 4px;
        color: var(--text-secondary);
        display: inline-block;
        margin-bottom: 16px;
      }

      /* FAQ */
      .faq-item {
        padding: 24px 0;
        border-bottom: 1px solid var(--border);
      }

      .faq-item:last-child {
        border-bottom: none;
      }

      .faq-item h3 {
        font-family: var(--font-serif);
        font-size: 22px;
        font-weight: 600;
        margin: 0 0 12px;
      }

      .faq-item p {
        margin: 0 0 8px;
        line-height: 1.7;
        color: var(--text-secondary);
      }

      /* Footer */
      .site-footer {
        padding: 48px 0;
        background: var(--bg-alt);
        border-top: 1px solid var(--border);
        font-family: var(--font-sans);
        font-size: 14px;
        color: var(--text-muted);
      }

      .site-footer a {
        color: var(--text-secondary);
      }

      .site-footer-inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 24px;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .hero {
          padding: 48px 0 32px;
        }
        .hero h1 {
          font-size: 36px;
        }
        .hero-lede {
          font-size: 17px;
        }
        .section {
          padding: 48px 0;
        }
        .section h2 {
          font-size: 28px;
        }
        .library-card {
          padding: 24px;
        }
        .library-card h3 {
          font-size: 22px;
        }
        .library-grid {
          grid-template-columns: 1fr;
          gap: 20px;
        }
      }
    </style>
  </body>
</html>
